@app.post("/submit")
def submit_answer(
    survey_id: int = Form(...),
    answer: str = Form(...)
):
    db = SessionLocal()

    db.add(Response(
        survey_id=survey_id,
        answer=answer
    ))

    db.commit()
    db.close()

    return RedirectResponse(url="/thank-you", status_code=303)


