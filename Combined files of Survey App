app = FastAPI()


# ---------------------------
# GET ALL SURVEY LINKS
# ---------------------------
@app.get("/survey-links")
def survey_links():
    db = SessionLocal()

    surveys = db.query(Survey).all()

    db.close()

    base_url = "http://127.0.0.1:8000/s/"

    return [
        {
            "id": s.id,
            "question": s.question,
            "link": base_url + s.slug
        }
        for s in surveys
    ]


# ---------------------------
# GET SINGLE SURVEY
# ---------------------------
@app.get("/s/{slug}")
def get_survey(slug: str):
    db = SessionLocal()

    survey = db.query(Survey).filter(Survey.slug == slug).first()

    db.close()

    if not survey:
        return {"error": "Survey not found"}

    return {
        "id": survey.id,
        "question": survey.question,
        "video_id": survey.video_id,
        "slug": survey.slug
    }


